// =====================================================
// schema.prisma - Definisi database CareConnect
// Sesuai ERD yang sudah dirancang
// =====================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =====================================================
// TABLE: users
// Berisi semua user (admin maupun user biasa)
// =====================================================
model User {
  id         String   @id @default(uuid())
  name       String
  email      String   @unique
  password   String
  role       String   @default("user") // "admin" atau "user"
  created_at DateTime @default(now())

  // Relasi: satu user bisa punya banyak project (sebagai owner)
  projects   Project[]   @relation("ProjectOwner")

  // Relasi: satu user bisa punya banyak donasi
  donations  Donation[]

  // Relasi: satu user bisa jadi volunteer di banyak project
  volunteers Volunteer[]

  @@map("users")
}

// =====================================================
// TABLE: projects
// Berisi semua project donasi/kegiatan sosial
// =====================================================
model Project {
  id               String   @id @default(uuid())
  title            String
  description      String
  image_url        String?
  target_donation  Decimal  @db.Decimal(15, 2)
  current_donation Decimal  @default(0) @db.Decimal(15, 2)
  deadline         DateTime @db.Date
  owner_id         String
  created_at       DateTime @default(now())

  // Relasi ke tabel users (siapa yang bikin project ini)
  owner      User        @relation("ProjectOwner", fields: [owner_id], references: [id])

  // Relasi: satu project bisa punya banyak donasi
  donations  Donation[]

  // Relasi: satu project bisa punya banyak volunteer
  volunteers Volunteer[]

  @@map("projects")
}

// =====================================================
// TABLE: donations
// Berisi semua transaksi donasi
// =====================================================
model Donation {
  id         String   @id @default(uuid())
  user_id    String
  project_id String
  amount     Decimal  @db.Decimal(15, 2)
  status     String   @default("pending") // "pending", "success", "failed"
  snap_token String?  // Token Midtrans Snap (payment gateway)
  proof_image String? // Bukti transfer donasi
  created_at DateTime @default(now())

  // Relasi ke tabel users (siapa yang donasi)
  user    User    @relation(fields: [user_id], references: [id])

  // Relasi ke tabel projects (donasi ke project mana)
  project Project @relation(fields: [project_id], references: [id])

  @@map("donations")
}

// =====================================================
// TABLE: volunteers
// Berisi semua pendaftaran volunteer
// =====================================================
model Volunteer {
  id         String   @id @default(uuid())
  user_id    String
  project_id String
  status     String   @default("pending") // "pending", "accepted", "rejected"
  joined_at  DateTime @default(now())

  // Relasi ke tabel users (siapa yang daftar jadi volunteer)
  user    User    @relation(fields: [user_id], references: [id])

  // Relasi ke tabel projects (volunteer untuk project mana)
  project Project @relation(fields: [project_id], references: [id])

  @@map("volunteers")
}
